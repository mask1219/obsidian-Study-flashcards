{
  "name": "obsidian-study-flashcards",
  "version": "0.1.1",
  "description": "Plugin for generating and reviewing study flashcards from notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "flashcards",
    "study"
  ],
  "author": "少爷",
  "license": "MIT",
  "dependencies": {
    "obsidian": "^1.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "builtin-modules": "^5.1.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
